# .env.example — copy to .env and fill in real values. .env is gitignored.

# ── GCP infra (consumed by deploy.sh and setup-turn.sh) ──────────────────────
PROJECT_ID=your-gcp-project
REGION=us-central1
ZONE=us-central1-a
SERVICE_NAME=signaling-server
VM_NAME=turn-server
TURN_REALM=example.com

# ── Discord OAuth (https://discord.com/developers/applications) ──────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Set after first deploy — Cloud Run URL + /auth/discord/callback
DISCORD_REDIRECT_URI=

# Optional — if set, signaling server posts LFG/match notifications here
DISCORD_WEBHOOK_URL=

# ── JWT signing key (48 random bytes, base64) ────────────────────────────────
# Generate with: openssl rand -base64 48
# If left blank, deploy.sh generates one on first deploy and preserves it.
JWT_SECRET=

# ── Optional stats service (separate Cloud Run service) ──────────────────────
STATS_SERVICE_URL=
STATS_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=signaling_server=debug,tower_http=debug
